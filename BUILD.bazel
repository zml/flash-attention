    name = "flashattn-sm90-support-files",
    textual_hdrs = glob(["hopper/instantiations/*.cu"]),
)

cuda_library(
    name = "flashattn-sm90",
    defines = [],
    deps = [
        "//:flashattn-sm90-headers",
        "//:flashattn-sm90-support-files",
        "//:cute",
        "//:cutlass",
        "//:c10_stub",
        "//:ATen_stub",
    ],
    copts = [
        "-U__CUDA_NO_HALF_OPERATORS__",
        "-U__CUDA_NO_HALF_CONVERSIONS__",
        "-U__CUDA_NO_HALF2_OPERATORS__",
        "-U__CUDA_NO_BFLOAT16_CONVERSIONS__",
        "--expt-relaxed-constexpr",
        "--expt-extended-lambda",
        "--use_fast_math",
        #"--generate-line-info",
    ],
    srcs = [
        "hopper/flash_prepare_scheduler.cu",
        "hopper/flash_fwd_combine.cu",
    ] 
    + glob(["hopper/instantiations/flash_fwd_hdimall_bf16*_sm90.cu"])
    + glob(["hopper/instantiations/flash_fwd_hdimdiff_bf16*_sm90.cu"])
    + glob(["hopper/instantiations/flash_fwd_*_bf16_*_sm80.cu"])
    + glob(["hopper/instantiations/flash_fwd_hdimall_fp16*_sm90.cu"])
    + glob(["hopper/instantiations/flash_fwd_hdimdiff_fp16*_sm90.cu"])
    + glob(["hopper/instantiations/flash_fwd_*_fp16_*_sm80.cu"])
    + glob(["hopper/instantiations/flash_fwd_hdimall_e4m3*_sm90.cu"])
    + glob(["hopper/instantiations/flash_fwd_hdimdiff_e4m3*_sm90.cu"]),
)

cuda_library(
    name = "capi-sm90",
    srcs = ["capi/capi_sm90.cu"],
